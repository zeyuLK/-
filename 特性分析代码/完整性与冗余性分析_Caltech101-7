import scipy.io as sio
import numpy as np

# 加载数据
data = sio.loadmat('dataset\Caltech101-7.mat')
X = data['X']
Y = data['Y']
views = data['X'][0]  # 6个视图

# 计算有效秩（修正版）
def 计算有效秩(特征矩阵):
    # SVD 奇异值分解
    U, S, V = np.linalg.svd(特征矩阵, full_matrices=False)
    # 归一化奇异值
    奇异值和 = np.sum(S)
    归一化奇异值 = S / 奇异值和
    # 计算熵（防止除0，加极小值）
    熵 = -np.sum(归一化奇异值 * np.log(归一化奇异值 + 1e-10))
    # 有效秩 = exp(熵)
    有效秩 = np.exp(熵)
    return 有效秩

# 遍历 6 个视图，计算结果
结果列表 = []
for 序号, 单个视图 in enumerate(views):
    有效秩结果 = 计算有效秩(单个视图)
    特征维度 = 单个视图.shape[1]
    有效秩占比 = 有效秩结果 / 特征维度
    结果列表.append([序号 + 1, 特征维度, 有效秩结果, 有效秩占比])

# 打印表格（清晰美观）
print("视图序号\t原始维度\t有效秩\t\t有效秩/总维度")
print("-" * 60)
for 行 in 结果列表:
    print(f"{行[0]}\t\t{行[1]}\t\t{行[2]:.2f}\t\t{行[3]:.2f}")