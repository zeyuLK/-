# 创建大图：2行3列
plt.figure(figsize=(18, 12))

for i, view in enumerate(views):
    # 计算相关系数矩阵
    corr_matrix = np.corrcoef(view.T)
    
    # 子图位置
    plt.subplot(2, 3, i+1)
    
    # 画热力图
    sns.heatmap(corr_matrix, cmap='coolwarm', center=0, square=True)
    
    # 子图标题
    plt.title(f'视图 {i+1} 特征相关性热力图')

# 整体布局调整
plt.tight_layout()
plt.show()

def corr_stats(view):
    corr = np.corrcoef(view.T)
    upper = corr[np.triu_indices_from(corr, k=1)]
    
    mean_corr = np.mean(np.abs(upper))
    high_corr_ratio = np.mean(np.abs(upper) > 0.8)
    
    return mean_corr, high_corr_ratio
stats = []
for i, view in enumerate(views):
    mean_corr, high_corr_ratio = corr_stats(view)
    stats.append([i+1, mean_corr, high_corr_ratio])

import pandas as pd
df_stats = pd.DataFrame(stats, columns=["View", "Mean Correlation", "High Correlation Ratio"])
print(df_stats)

