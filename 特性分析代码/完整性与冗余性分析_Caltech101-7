import scipy.io as sio
import numpy as np
from sklearn.decomposition import PCA
from sklearn.preprocessing import StandardScaler
import matplotlib.pyplot as plt

# 解决中文显示问题
plt.rcParams['font.sans-serif'] = ['SimHei']  # 黑体
plt.rcParams['axes.unicode_minus'] = False    # 解决负号显示问题

data = sio.loadmat('dataset\Caltech101-7.mat')

X = data['X']
Y = data['Y']

views = data['X'][0]
print("视图数量：", len(views))

for i, v in enumerate(views):
    print(f"视图 {i+1}: shape = {v.shape}")

# 绘图（全中文）
plt.figure(figsize=(8,6))

for i, view in enumerate(views):
    view = view.astype(float)
    view = StandardScaler().fit_transform(view)
    
    pca = PCA().fit(view)
    cum_var = np.cumsum(pca.explained_variance_ratio_)
    
    plt.plot(cum_var, label=f'视图 {i+1}')

# 90% 参考线
plt.axhline(y=0.9, linestyle='--', label='90%方差')

# 全中文坐标轴与标题
plt.xlabel('主成分个数')
plt.ylabel('累积解释方差占比')
plt.title('多视图PCA方差累积曲线')
plt.legend()
plt.grid()
plt.show()

# 统计类别数
Y_flat = Y.ravel()
num_classes = len(np.unique(Y_flat))
print("类别总数：", num_classes)

results = []

for i, view in enumerate(views):
    view = StandardScaler().fit_transform(view.astype(float))
    
    pca = PCA().fit(view)
    cum_var = np.cumsum(pca.explained_variance_ratio_)
    
    k_90 = np.argmax(cum_var >= 0.9) + 1
    d = view.shape[1]
    
    results.append([i+1, d, k_90, k_90/d])

import pandas as pd
df = pd.DataFrame(results, columns=["View","Dimension","k_90","Compression"])
print(df)

